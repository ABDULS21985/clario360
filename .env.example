# =============================================================================
# Clario 360 — Environment Configuration
# Copy this file to .env and adjust values for your environment
# =============================================================================

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=30s

# --- Database (PostgreSQL 16) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=clario
DATABASE_PASSWORD=clario_dev_pass
DATABASE_NAME=clario360
DATABASE_SSL_MODE=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=5m

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=clario360
KAFKA_AUTO_OFFSET_RESET=earliest

# --- Auth / JWT ---
AUTH_JWT_SECRET=change-me-in-production-use-256-bit-key
AUTH_JWT_ISSUER=clario360
AUTH_JWT_ACCESS_TOKEN_TTL=15m
AUTH_JWT_REFRESH_TOKEN_TTL=7d
AUTH_BCRYPT_COST=12

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=clario_minio
MINIO_SECRET_KEY=clario_minio_secret
MINIO_USE_SSL=false
MINIO_BUCKET=clario360

# --- Keycloak (optional external IdP) ---
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=clario360
KEYCLOAK_CLIENT_ID=clario-api
KEYCLOAK_CLIENT_SECRET=change-me

# --- Observability ---
LOG_LEVEL=debug
LOG_FORMAT=json
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=clario360
METRICS_ENABLED=true
METRICS_PORT=9090

# --- Encryption ---
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# --- Schema Registry ---
SCHEMA_REGISTRY_URL=http://localhost:8081
