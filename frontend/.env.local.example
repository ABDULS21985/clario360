# ── API ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Clario 360
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0

# ── Auth cookies (used by BFF API routes) ────────────────────────────────────
# Cookie name prefix
AUTH_COOKIE_NAME=clario360

# Set to "false" in development (localhost has no HTTPS)
# MUST be "true" in production
AUTH_COOKIE_SECURE=false

AUTH_COOKIE_DOMAIN=localhost
AUTH_COOKIE_SAMESITE=strict

# Token max ages in seconds
AUTH_ACCESS_TOKEN_MAX_AGE=900       # 15 minutes
AUTH_REFRESH_TOKEN_MAX_AGE=604800   # 7 days
