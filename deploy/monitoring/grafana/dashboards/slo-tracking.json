          "editorMode": "code",
          "expr": "clario360:slo:error_budget_remaining{namespace=~\"$namespace\"} * (30 * 24 * 3600) / clamp_min(clario360:slo:burn_rate:1h{namespace=~\"$namespace\"}, 0.001)",
