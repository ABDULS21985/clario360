          "editorMode": "code",
          "expr": "sum(rate(clario360_kafka_messages_consumed_total{namespace=~\"$namespace\", topic=~\"$topic\", direction=\"produce\"}[$__rate_interval]))",
          "legendFormat": "Produce Rate",
